# Server
PORT=3001
NODE_ENV=development

# MongoDB (Mongoose)
MONGODB_URI=mongodb://127.0.0.1:27017/YOUR_DATABASE_NAME

# CORS — frontend origin (e.g. Vite dev server)
# CORS_ORIGIN=http://localhost:3000

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=titanos
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=http://localhost:9000

# Media — opaque MinIO object keys (min 32 chars; HMAC + random salt, not UUID)
MEDIA_OBJECT_KEY_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# JWT (use long random secrets in production)
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Uploads (bytes)
MAX_FILE_SIZE=52428800
