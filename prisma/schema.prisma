generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
  PLAYER
  FAN
}

enum MemberType {
  PLAYER
  COACH
  STAFF
}

enum Position {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
  WINGER
  STRIKER
  OTHER
}

enum InjuryType {
  MUSCLE
  LIGAMENT
  TENDON
  BONE
  CONCUSSION
  JOINT
  OTHER
}

enum SessionType {
  TRAINING
  MATCH
  MEETING
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

enum MatchEventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  INJURY
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  refreshToken String?
  role         Role     @default(PLAYER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member      Member?
  articles    Article[]
  fanActions  FanAction[]
  auditLogs   AuditLog[]
  media       Media[]

  @@map("users")
}

model Member {
  id           String     @id @default(uuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id])
  firstName    String
  lastName     String
  position     Position?
  jerseyNumber Int?
  type         MemberType @default(PLAYER)
  teamId       String?
  team         Team?      @relation(fields: [teamId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions         SessionMember[]
  matchEvents      MatchEvent[]
  medicalRecords   MedicalRecord[]
  wellnessForms    WellnessForm[]
  aiInsights       AIInsight[]
  performances     Performance[]

  @@index([teamId])
  @@map("members")
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  sport     String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     Member[]
  sessions    Session[]
  homeMatches  Match[]        @relation("HomeTeam")
  awayMatches  Match[]        @relation("AwayTeam")
  tacticalHubs TacticalHub[]
  media        Media[]

  @@map("teams")
}

model Session {
  id        String      @id @default(uuid())
  title     String
  type      SessionType
  date      DateTime
  duration  Int?
  location  String?
  teamId    String
  team      Team        @relation(fields: [teamId], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  participants SessionMember[]
  performances Performance[]
  tacticalHubs TacticalHub[]

  @@index([teamId])
  @@index([date])
  @@map("sessions")
}

model SessionMember {
  sessionId String
  memberId  String
  session   Session @relation(fields: [sessionId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])

  @@id([sessionId, memberId])
  @@map("session_members")
}

model Match {
  id          String      @id @default(uuid())
  homeTeamId  String
  awayTeamId  String
  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore   Int         @default(0)
  awayScore   Int         @default(0)
  status      MatchStatus @default(SCHEDULED)
  scheduledAt DateTime
  venue       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  events     MatchEvent[]
  fanActions FanAction[]

  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledAt])
  @@index([status])
  @@map("matches")
}

model MatchEvent {
  id        String         @id @default(uuid())
  matchId   String
  match     Match          @relation(fields: [matchId], references: [id])
  memberId  String?
  member    Member?        @relation(fields: [memberId], references: [id])
  type      MatchEventType
  minute    Int
  detail    String?
  createdAt DateTime       @default(now())

  @@index([matchId])
  @@index([memberId])
  @@map("match_events")
}

model Article {
  id          String        @id @default(uuid())
  title       String
  content     String
  coverImage  String?
  status      ArticleStatus @default(DRAFT)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([authorId])
  @@index([status])
  @@map("articles")
}

enum FanActionType {
  VOTE
  TICKET_PURCHASE
  LIKE
  SHARE
}

model FanAction {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  matchId   String?
  match     Match?        @relation(fields: [matchId], references: [id])
  type      FanActionType
  payload   Json?
  createdAt DateTime      @default(now())

  @@index([userId])
  @@index([matchId])
  @@map("fan_actions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model MedicalRecord {
  id          String      @id @default(uuid())
  memberId    String
  member      Member      @relation(fields: [memberId], references: [id])
  diagnosis   String
  injuryType  InjuryType?
  treatment   String?
  notes       String?
  fileUrls    String[]
  recordedAt  DateTime
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([memberId])
  @@index([recordedAt])
  @@map("medical_records")
}

model WellnessForm {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  fatigue   Int
  sleep     Int
  stress    Int
  mood      Int?
  notes     String?
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([date])
  @@map("wellness_forms")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model AIInsight {
  id             String    @id @default(uuid())
  memberId       String
  member         Member    @relation(fields: [memberId], references: [id])
  riskLevel      RiskLevel
  summary        String
  recommendation String?
  dataWindow     Int
  generatedAt    DateTime  @default(now())

  @@index([memberId])
  @@index([generatedAt])
  @@map("ai_insights")
}

model Performance {
  id         String   @id @default(uuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  sessionId  String?
  session    Session? @relation(fields: [sessionId], references: [id])
  distance   Float?
  speed      Float?
  rating     Int?
  notes      String?
  recordedAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([memberId])
  @@index([sessionId])
  @@map("performances")
}

enum TacticalContentType {
  FORMATION
  PLAY
  ANALYSIS
  HIGHLIGHT
}

model TacticalHub {
  id          String              @id @default(uuid())
  title       String
  description String?
  contentType TacticalContentType
  teamId      String
  team        Team                @relation(fields: [teamId], references: [id])
  sessionId   String?
  session     Session?            @relation(fields: [sessionId], references: [id])
  mediaId     String?             @unique
  media       Media?              @relation(fields: [mediaId], references: [id])
  createdBy   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([teamId])
  @@index([sessionId])
  @@map("tactical_hubs")
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  TACTICAL
}

enum MediaAccess {
  PUBLIC
  PRIVATE
  TEAM
}

model Media {
  id         String      @id @default(uuid())
  filename   String
  fileUrl    String
  bucketName String
  objectKey  String      @unique
  mimeType   String
  size       Int
  type       MediaType
  access     MediaAccess @default(PRIVATE)
  ownerId    String
  owner      User        @relation(fields: [ownerId], references: [id])
  teamId     String?
  team       Team?       @relation(fields: [teamId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tacticalHub TacticalHub?

  @@index([ownerId])
  @@index([teamId])
  @@map("media")
}
