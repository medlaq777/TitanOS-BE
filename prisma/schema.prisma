generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
  PLAYER
  FAN
}

enum MemberType {
  PLAYER
  COACH
  STAFF
}

enum SessionType {
  TRAINING
  MATCH
  MEETING
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

enum MatchEventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  INJURY
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id         String   @id @default(uuid())
  keycloakId String   @unique
  email      String   @unique
  role       Role     @default(PLAYER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  member      Member?
  articles    Article[]
  fanActions  FanAction[]
  auditLogs   AuditLog[]

  @@map("users")
}

model Member {
  id           String     @id @default(uuid())
  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id])
  firstName    String
  lastName     String
  position     String?
  jerseyNumber Int?
  type         MemberType @default(PLAYER)
  teamId       String?
  team         Team?      @relation(fields: [teamId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions    SessionMember[]
  matchEvents MatchEvent[]

  @@map("members")
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  sport     String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     Member[]
  sessions    Session[]
  homeMatches Match[]   @relation("HomeTeam")
  awayMatches Match[]   @relation("AwayTeam")

  @@map("teams")
}

model Session {
  id        String      @id @default(uuid())
  title     String
  type      SessionType
  date      DateTime
  duration  Int?
  location  String?
  teamId    String
  team      Team        @relation(fields: [teamId], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  participants SessionMember[]

  @@map("sessions")
}

model SessionMember {
  sessionId String
  memberId  String
  session   Session @relation(fields: [sessionId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])

  @@id([sessionId, memberId])
  @@map("session_members")
}

model Match {
  id          String      @id @default(uuid())
  homeTeamId  String
  awayTeamId  String
  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore   Int         @default(0)
  awayScore   Int         @default(0)
  status      MatchStatus @default(SCHEDULED)
  scheduledAt DateTime
  venue       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  events     MatchEvent[]
  fanActions FanAction[]

  @@map("matches")
}

model MatchEvent {
  id        String         @id @default(uuid())
  matchId   String
  match     Match          @relation(fields: [matchId], references: [id])
  memberId  String?
  member    Member?        @relation(fields: [memberId], references: [id])
  type      MatchEventType
  minute    Int
  detail    String?
  createdAt DateTime       @default(now())

  @@map("match_events")
}

model Article {
  id          String        @id @default(uuid())
  title       String
  content     String
  coverImage  String?
  status      ArticleStatus @default(DRAFT)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("articles")
}

enum FanActionType {
  VOTE
  TICKET_PURCHASE
  LIKE
  SHARE
}

model FanAction {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  matchId   String?
  match     Match?        @relation(fields: [matchId], references: [id])
  type      FanActionType
  payload   Json?
  createdAt DateTime      @default(now())

  @@map("fan_actions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
